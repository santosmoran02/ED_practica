	@Test
	public void test_ProgressIterator() {
		ArrayEDList<String> lista = new ArrayEDList<String>();
		lista.addFirst("6");
		lista.addFirst("5");
		Iterator<String> it = lista.progressIterator();
		assertTrue(it.hasNext());
		it.next();
		assertTrue(it.hasNext());
		it.next();
		assertTrue(it.hasNext());
		it.next();
		assertFalse(it.hasNext());
	}
	
