	@Test
	public void test_hasNext() {
		ArrayEDList<String> lista1 = new ArrayEDList<String>(2);
		lista1.addFirst("A");
		Iterator<String> it = lista1.iterator();
		assertTrue(it.hasNext());
		it.next();
		assertFalse(it.hasNext());
	}
	
	@Test
	public void test_OddIterator() {
		ArrayEDList<String> lista = new ArrayEDList<String>();
		lista.addFirst("7");
		lista.addFirst("6");
		lista.addFirst("5");
		Iterator<String> it = lista.oddPositionsIterator();
		assertTrue(it.hasNext());
		it.next();
		assertTrue(it.hasNext());
		it.next();
		assertFalse(it.hasNext());
	}
	
