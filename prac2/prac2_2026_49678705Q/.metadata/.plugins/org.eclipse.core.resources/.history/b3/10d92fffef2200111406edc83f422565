	@Test
	public void test_intersect_aparecen(){
		ArrayEDList<String> lista = new ArrayEDList<String>(10);
		lista.addFirst("A");
		lista.addFirst("B");
		ArrayEDList<String> lista1 = new ArrayEDList<String>(10);
		lista1.addFirst("B");
		assertEquals(1, lista.intersec(lista1));
		lista.addFirst("A");
		lista.addFirst("B");
		lista.addFirst("C");
		lista.addFirst("D");
		lista1.addFirst("D");
		assertEquals(2, lista.intersec(lista1));
	}
	
