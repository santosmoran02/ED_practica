	        assertEquals(1, gym.getNumberOfOccupiedLockers());
	        assertEquals(4, gym.getNumberOfAvailableLockers());

	        assertNotNull(gym.getLocker(3));
	        assertEquals("111A", gym.getLocker(3).getNif());
	    }
	    
