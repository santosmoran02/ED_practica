	    @Test
	    public void testRentFirstAvailableLocker_assignsFirst() {
	        // ocupa 1 y 2
	        assertTrue(gym.rentLockerAtPosition(1, "111A", "Ana", 20, UserType.BASIC));
	        assertTrue(gym.rentLockerAtPosition(2, "222B", "Luis", 21, UserType.BASIC));

	        int pos = gym.rentFirstAvailableLocker("333C", "Laura", 19, UserType.BASIC);
	        assertEquals(3, pos); // primera libre debería ser la 3
	    }

	    @Test
	    public void testPremiumPaysZero_basicPaysPrice() {
	        // BASIC normal
	        assertTrue(gym.rentLockerAtPosition(1, "111A", "Ana", 20, UserType.BASIC));
	        // PREMIUM normal
	        assertTrue(gym.rentLockerAtPosition(2, "222B", "Luis", 21, UserType.PREMIUM));

	        // total = price (solo BASIC)
	        assertEquals(gym.getPrice(), gym.getTotalCollection(), 1.0);
	    }
	    
