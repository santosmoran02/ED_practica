	@Override
	public boolean contains(T elem) {
		if (elem == null) {
			throw new NullPointerException("Error, el elemento no puede ser nulo\n");
		}
		
		DoubleNode<T> aux = front;
		boolean encontrado = false;
		
		while(aux != null) {
			if (aux.elem.equals(elem)) {
				return true;
			}
			aux = aux.next;
		}
		return encontrado;
	}

	@Override
	public int size() {
		int contador = 0;
		DoubleNode<T> aux = front;
		while (aux != null) {
			aux  = aux.next;
			contador++;
		}
		return contador;
	}

	@Override
	public int countInstances() {
		DoubleNode<T> aux = front;
		int contador = 0;
		while(aux != null) {
			contador += aux.count;
			aux = aux.next;
			
		}
		return contador;
	}

